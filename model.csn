    "kikuldetes.PostingsWithCar": {
      "kind": "entity",
      "@restrict": [
        {
          "grant": "*",
          "to": "Backoffice"
        },
        {
          "grant": "*",
          "where": "employee_ID = $user.id"
        }
      ],
      "includes": [
        "kikuldetes.Postings",
        "kikuldetes.Car"
      ],
      "elements": {
        "createdAt": {
          "@cds.on.insert": {
            "=": "$now"
          },
          "@UI.HiddenFilter": true,
          "@UI.ExcludeFromNavigationContext": true,
          "@Core.Immutable": true,
          "@title": "{i18n>CreatedAt}",
          "@readonly": true,
          "type": "cds.Timestamp"
        },
        "createdBy": {
          "@cds.on.insert": {
            "=": "$user"
          },
          "@UI.HiddenFilter": true,
          "@UI.ExcludeFromNavigationContext": true,
          "@Core.Immutable": true,
          "@title": "{i18n>CreatedBy}",
          "@readonly": true,
          "@description": "{i18n>UserID.Description}",
          "type": "User",
          "length": 255
        },
        "modifiedAt": {
          "@cds.on.insert": {
            "=": "$now"
          },
          "@cds.on.update": {
            "=": "$now"
          },
          "@UI.HiddenFilter": true,
          "@UI.ExcludeFromNavigationContext": true,
          "@title": "{i18n>ChangedAt}",
          "@readonly": true,
          "type": "cds.Timestamp"
        },
        "modifiedBy": {
          "@cds.on.insert": {
            "=": "$user"
          },
          "@cds.on.update": {
            "=": "$user"
          },
          "@UI.HiddenFilter": true,
          "@UI.ExcludeFromNavigationContext": true,
          "@title": "{i18n>ChangedBy}",
          "@readonly": true,
          "@description": "{i18n>UserID.Description}",
          "type": "User",
          "length": 255
        },
        "ID": {
          "key": true,
          "type": "cds.UUID"
        },
        "goal": {
          "@mandatory": true,
          "type": "cds.String"
        },
        "employee": {
          "type": "cds.Association",
          "cardinality": {
            "max": 1
          },
          "target": "kikuldetes.Employees",
          "keys": [
            {
              "ref": [
                "ID"
              ]
            }
          ]
        },
        "status": {
          "type": "cds.Association",
          "cardinality": {
            "max": 1
          },
          "target": "kikuldetes.Statuses",
          "keys": [
            {
              "ref": [
                "ID"
              ]
            }
          ]
        },
        "restriction": {
          "@UI.Hidden": true,
          "type": "cds.Integer",
          "default": {
            "val": 0
          }
        },
        "attachments": {
          "@attachments.disable_facet": true,
          "type": "cds.Composition",
          "cardinality": {
            "max": "*"
          },
          "targetAspect": "Attachments",
          "target": "kikuldetes.PostingsWithCar.attachments",
          "on": [
            {
              "ref": [
                "attachments",
                "up_"
              ]
            },
            "=",
            {
              "ref": [
                "$self"
              ]
            }
          ]
        },
        "submittable": {
          "@Core.Computed": true,
          "virtual": true,
          "type": "cds.Boolean",
          "default": {
            "val": true
          }
        },
        "backOffice": {
          "@UI.Hidden": true,
          "@Core.Computed": true,
          "virtual": true,
          "type": "cds.Boolean",
          "default": {
            "val": false
          }
        },
        "serialNumber": {
          "type": "cds.String"
        },
        "serialNumberEntity": {
          "type": "cds.Association",
          "cardinality": {
            "max": 1
          },
          "target": "kikuldetes.SerialNumbers",
          "keys": [
            {
              "ref": [
                "yearMonth"
              ]
            },
            {
              "ref": [
                "number"
              ]
            }
          ]
        },
        "editing": {
          "@Core.Computed": true,
          "virtual": true,
          "type": "cds.Boolean",
          "default": {
            "val": false
          }
        },
        "accepted": {
          "@Core.Computed": true,
          "virtual": true,
          "type": "cds.Boolean",
          "default": {
            "val": false
          }
        },
        "fuel_type": {
          "@mandatory": true,
          "type": "cds.Association",
          "cardinality": {
            "max": 1
          },
          "target": "kikuldetes.FuelTypes",
          "keys": [
            {
              "ref": [
                "ID"
              ]
            }
          ]
        },
        "plateNum": {
          "@mandatory": true,
          "type": "cds.String"
        },
        "cylinder_volume": {
          "type": "cds.Integer"
        },
        "data": {
          "type": "cds.Composition",
          "cardinality": {
            "max": "*"
          },
          "target": "kikuldetes.PostingDataWithCar",
          "on": [
            {
              "ref": [
                "data",
                "posting"
              ]
            },
            "=",
            {
              "ref": [
                "$self"
              ]
            }
          ]
        },
        "stickers": {
          "type": "cds.Composition",
          "cardinality": {
            "max": "*"
          },
          "target": "kikuldetes.HighwayStickers",
          "on": [
            {
              "ref": [
                "stickers",
                "posting"
              ]
            },
            "=",
            {
              "ref": [
                "$self"
              ]
            }
          ]
        },
        "messages": {
          "type": "cds.Composition",
          "cardinality": {
            "max": "*"
          },
          "target": "kikuldetes.CarStatusMessages",
          "on": [
            {
              "ref": [
                "messages",
                "posting"
              ]
            },
            "=",
            {
              "ref": [
                "$self"
              ]
            }
          ]
        }
      }
    },
