          "type": "Currency",
          "target": "sap.common.Currencies",
          "keys": [
            {
              "ref": [
                "code"
              ]
            }
          ]
        },
        "daily_price": {
          "@mandatory": true,
          "type": "cds.Decimal",
          "precision": 10,
          "scale": 2
        },
        "ID": {
          "key": true,
          "type": "cds.UUID"
        },
        "paymentMethod": {
          "type": "cds.Association",
          "cardinality": {
            "max": 1
          },
          "target": "kikuldetes.PaymentMethods",
          "keys": [
            {
              "ref": [
                "ID"
              ]
            }
          ]
        },
        "date": {
          "@mandatory": true,
          "type": "cds.Date"
        },
        "posting": {
          "type": "cds.Association",
