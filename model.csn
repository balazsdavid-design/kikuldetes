        },
        "accepted": {
          "@Core.Computed": true,
          "virtual": true,
          "type": "cds.Boolean",
          "default": {
            "val": false
          }
        }
      }
    },
    "kikuldetes.Statuses": {
      "kind": "entity",
      "elements": {
        "ID": {
          "key": true,
          "type": "cds.Integer"
        },
        "statusText": {
          "@mandatory": true,
          "localized": true,
          "type": "cds.String"
        },
        "texts": {
          "type": "cds.Composition",
          "cardinality": {
            "max": "*"
          },
          "target": "kikuldetes.Statuses.texts",
          "on": [
            {
              "ref": [
                "texts",
                "ID"
              ]
            },
            "=",
            {
              "ref": [
                "ID"
              ]
            }
          ]
        },
        "localized": {
          "type": "cds.Association",
          "target": "kikuldetes.Statuses.texts",
          "on": [
            {
              "ref": [
                "localized",
                "ID"
              ]
            },
            "=",
            {
              "ref": [
                "ID"
              ]
            },
            "and",
            {
              "ref": [
                "localized",
                "locale"
              ]
            },
            "=",
            {
              "ref": [
                "$user",
                "locale"
              ]
            }
          ]
        }
      }
    },
    "kikuldetes.RegularStatusMessages": {
      "kind": "entity",
      "@UI.DeleteHidden": {
        "=": "not posting.backOffice",
        "xpr": [
          "not",
          {
            "ref": [
              "posting",
              "backOffice"
            ]
          }
        ]
      },
      "@UI.CreateHidden": true,
      "elements": {
        "ID": {
          "key": true,
          "type": "cds.UUID"
        },
        "restriction": {
          "@Core.Computed": true,
