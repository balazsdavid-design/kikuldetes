      ],
      "elements": {
        "ID": {
          "key": true,
          "type": "cds.UUID"
        },
        "reference": {
          "@mandatory": true,
          "type": "cds.String"
        },
        "date": {
          "@mandatory": true,
          "type": "cds.Date"
        },
        "name": {
          "@mandatory": true,
          "type": "cds.String"
        },
        "currency": {
          "@title": "{i18n>Currency}",
          "@description": "{i18n>CurrencyCode.Description}",
          "type": "Currency",
          "target": "sap.common.Currencies",
          "keys": [
            {
              "ref": [
                "code"
              ]
            }
          ]
        },
        "price": {
          "@mandatory": true,
          "type": "cds.Decimal",
          "precision": 10,
          "scale": 2
        },
        "posting": {
          "type": "cds.Association",
          "target": "kikuldetes.PostingsRegular",
          "keys": [
            {
              "ref": [
                "ID"
              ]
            }
          ]
        },
        "paymentMethod": {
          "type": "cds.Association",
          "cardinality": {
            "max": 1
          },
          "target": "kikuldetes.PaymentMethods",
          "keys": [
            {
              "ref": [
                "ID"
              ]
            }
          ]
        }
      }
    },
    "kikuldetes.Postings": {
      "kind": "aspect",
      "@restrict": [
        {
          "grant": "*",
          "to": "Backoffice"
        },
        {
          "grant": "*",
          "where": "employee_ID = $user.id"
        }
      ],
      "includes": [
        "managed"
      ],
      "elements": {
        "createdAt": {
          "@cds.on.insert": {
            "=": "$now"
          },
          "@UI.HiddenFilter": true,
          "@UI.ExcludeFromNavigationContext": true,
          "@Core.Immutable": true,
          "@title": "{i18n>CreatedAt}",
          "@readonly": true,
          "type": "cds.Timestamp"
        },
        "createdBy": {
          "@cds.on.insert": {
            "=": "$user"
          },
          "@UI.HiddenFilter": true,
          "@UI.ExcludeFromNavigationContext": true,
          "@Core.Immutable": true,
          "@title": "{i18n>CreatedBy}",
          "@readonly": true,
          "@description": "{i18n>UserID.Description}",
          "type": "User",
          "length": 255
        },
        "modifiedAt": {
          "@cds.on.insert": {
            "=": "$now"
          },
          "@cds.on.update": {
            "=": "$now"
          },
          "@UI.HiddenFilter": true,
          "@UI.ExcludeFromNavigationContext": true,
          "@title": "{i18n>ChangedAt}",
          "@readonly": true,
          "type": "cds.Timestamp"
        },
        "modifiedBy": {
          "@cds.on.insert": {
            "=": "$user"
          },
          "@cds.on.update": {
            "=": "$user"
          },
          "@UI.HiddenFilter": true,
          "@UI.ExcludeFromNavigationContext": true,
          "@title": "{i18n>ChangedBy}",
          "@readonly": true,
          "@description": "{i18n>UserID.Description}",
          "type": "User",
          "length": 255
        },
        "ID": {
          "key": true,
          "type": "cds.UUID"
        },
        "goal": {
          "@mandatory": true,
          "type": "cds.String"
        },
        "employee": {
          "type": "cds.Association",
          "cardinality": {
            "max": 1
          },
          "target": "kikuldetes.Employees",
          "keys": [
            {
              "ref": [
                "ID"
              ]
            }
          ]
        },
        "status": {
          "type": "cds.Association",
          "cardinality": {
            "max": 1
          },
          "target": "kikuldetes.Statuses",
          "keys": [
            {
              "ref": [
                "ID"
              ]
            }
          ]
        },
        "restriction": {
          "@UI.Hidden": true,
          "type": "cds.Integer",
          "default": {
            "val": 0
          }
        },
        "attachments": {
          "@attachments.disable_facet": true,
          "type": "cds.Composition",
          "cardinality": {
            "max": "*"
          },
          "targetAspect": "Attachments"
        },
        "submittable": {
          "@Core.Computed": true,
          "virtual": true,
          "type": "cds.Boolean",
          "default": {
            "val": true
          }
        },
        "backOffice": {
          "@UI.Hidden": true,
          "@Core.Computed": true,
          "virtual": true,
          "type": "cds.Boolean",
          "default": {
            "val": false
          }
        },
        "serialNumber": {
          "type": "cds.String"
        },
        "serialNumberEntity": {
          "type": "cds.Association",
          "cardinality": {
            "max": 1
          },
          "target": "kikuldetes.SerialNumbers",
          "keys": [
            {
              "ref": [
                "yearMonth"
              ]
            },
            {
              "ref": [
                "number"
              ]
            }
          ]
        },
        "editing": {
          "@Core.Computed": true,
          "virtual": true,
          "type": "cds.Boolean",
          "default": {
            "val": false
