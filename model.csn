          "keys": [
            {
              "ref": [
                "ID"
              ]
            }
          ]
        }
      }
    },
    "kikuldetes.Accomodations": {
      "kind": "entity",
      "includes": [
        "kikuldetes.Expense"
      ],
      "elements": {
        "days": {
          "@mandatory": true,
          "type": "cds.Integer"
        },
        "currency": {
          "@mandatory": true,
          "@title": "{i18n>Currency}",
          "@description": "{i18n>CurrencyCode.Description}",
          "type": "Currency",
          "target": "sap.common.Currencies",
          "keys": [
            {
              "ref": [
                "code"
              ]
            }
          ]
        },
        "daily_price": {
          "@mandatory": true,
          "type": "cds.Decimal",
          "precision": 10,
          "scale": 2
        },
        "ID": {
          "key": true,
          "type": "cds.UUID"
        },
        "paymentMethod": {
          "type": "cds.Association",
          "cardinality": {
            "max": 1
          },
          "target": "kikuldetes.PaymentMethods",
          "keys": [
            {
              "ref": [
                "ID"
              ]
            }
          ]
        },
        "date": {
          "@mandatory": true,
          "type": "cds.Date"
        },
        "posting": {
          "type": "cds.Association",
          "target": "kikuldetes.PostingsRegular",
          "keys": [
            {
              "ref": [
                "ID"
              ]
            }
          ]
        },
        "accomodation_name": {
          "@mandatory": true,
          "type": "cds.String"
        },
        "invoiceDate": {
          "@mandatory": true,
          "type": "cds.Date"
        }
      }
    },
    "kikuldetes.OtherExpense": {
      "kind": "aspect",
      "elements": {
        "ID": {
          "key": true,
          "type": "cds.UUID"
        },
        "reference": {
          "@mandatory": true,
          "type": "cds.String"
        },
        "date": {
          "@mandatory": true,
          "type": "cds.Date"
        },
        "name": {
          "@mandatory": true,
          "type": "cds.String"
        },
        "currency": {
          "@title": "{i18n>Currency}",
          "@description": "{i18n>CurrencyCode.Description}",
          "type": "Currency",
          "target": "sap.common.Currencies",
          "keys": [
            {
              "ref": [
                "code"
              ]
            }
          ]
        },
        "price": {
          "@mandatory": true,
          "type": "cds.Decimal",
          "precision": 10,
          "scale": 2
        },
        "posting": {
          "type": "cds.Association",
          "target": "kikuldetes.PostingsRegular",
          "keys": [
            {
              "ref": [
                "ID"
              ]
            }
          ]
        },
        "paymentMethod": {
          "type": "cds.Association",
          "cardinality": {
            "max": 1
          },
          "target": "kikuldetes.PaymentMethods",
          "keys": [
            {
              "ref": [
                "ID"
              ]
            }
          ]
        }
      }
    },
    "kikuldetes.MaterialExpenses": {
      "kind": "entity",
      "includes": [
        "kikuldetes.OtherExpense"
      ],
      "elements": {
        "ID": {
          "key": true,
          "type": "cds.UUID"
        },
        "reference": {
          "@mandatory": true,
          "type": "cds.String"
        },
        "date": {
          "@mandatory": true,
          "type": "cds.Date"
        },
        "name": {
          "@mandatory": true,
          "type": "cds.String"
        },
        "currency": {
          "@title": "{i18n>Currency}",
          "@description": "{i18n>CurrencyCode.Description}",
          "type": "Currency",
          "target": "sap.common.Currencies",
          "keys": [
            {
              "ref": [
                "code"
              ]
            }
          ]
        },
        "price": {
          "@mandatory": true,
          "type": "cds.Decimal",
          "precision": 10,
          "scale": 2
        },
        "posting": {
          "type": "cds.Association",
          "target": "kikuldetes.PostingsRegular",
          "keys": [
            {
              "ref": [
                "ID"
              ]
            }
          ]
        },
        "paymentMethod": {
          "type": "cds.Association",
          "cardinality": {
            "max": 1
          },
          "target": "kikuldetes.PaymentMethods",
          "keys": [
            {
              "ref": [
                "ID"
              ]
            }
          ]
        }
      }
    },
    "kikuldetes.TripExpenses": {
      "kind": "entity",
      "includes": [
