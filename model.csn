{
  "namespace": "kikuldetes",
  "definitions": {
    "kikuldetes.PostingsRegular": {
      "kind": "entity",
      "@restrict": [
        {
          "grant": "*",
          "to": "Backoffice"
        },
        {
          "grant": "*",
          "where": "employee_ID = $user.id"
        }
      ],
      "includes": [
        "kikuldetes.Postings"
      ],
      "elements": {
        "createdAt": {
          "@cds.on.insert": {
            "=": "$now"
          },
          "@UI.HiddenFilter": true,
          "@UI.ExcludeFromNavigationContext": true,
          "@Core.Immutable": true,
          "@title": "{i18n>CreatedAt}",
          "@readonly": true,
          "type": "cds.Timestamp"
        },
        "createdBy": {
          "@cds.on.insert": {
            "=": "$user"
          },
          "@UI.HiddenFilter": true,
          "@UI.ExcludeFromNavigationContext": true,
          "@Core.Immutable": true,
          "@title": "{i18n>CreatedBy}",
          "@readonly": true,
          "@description": "{i18n>UserID.Description}",
          "type": "User",
          "length": 255
        },
        "modifiedAt": {
          "@cds.on.insert": {
            "=": "$now"
          },
          "@cds.on.update": {
            "=": "$now"
          },
          "@UI.HiddenFilter": true,
          "@UI.ExcludeFromNavigationContext": true,
          "@title": "{i18n>ChangedAt}",
          "@readonly": true,
          "type": "cds.Timestamp"
        },
        "modifiedBy": {
          "@cds.on.insert": {
            "=": "$user"
          },
          "@cds.on.update": {
            "=": "$user"
          },
          "@UI.HiddenFilter": true,
          "@UI.ExcludeFromNavigationContext": true,
          "@title": "{i18n>ChangedBy}",
          "@readonly": true,
          "@description": "{i18n>UserID.Description}",
          "type": "User",
          "length": 255
        },
        "ID": {
          "key": true,
          "type": "cds.UUID"
        },
        "goal": {
          "@mandatory": true,
          "type": "cds.String"
        },
        "employee": {
          "type": "cds.Association",
          "cardinality": {
            "max": 1
          },
          "target": "kikuldetes.Employees",
          "keys": [
            {
              "ref": [
                "ID"
              ]
            }
          ]
        },
        "status": {
          "type": "cds.Association",
          "cardinality": {
            "max": 1
          },
          "target": "kikuldetes.Statuses",
          "keys": [
            {
              "ref": [
                "ID"
              ]
            }
          ]
        },
        "restriction": {
          "@UI.Hidden": true,
          "type": "cds.Integer",
          "default": {
            "val": 0
          }
        },
        "attachments": {
          "@attachments.disable_facet": true,
          "type": "cds.Composition",
          "cardinality": {
            "max": "*"
          },
          "targetAspect": "Attachments",
          "target": "kikuldetes.PostingsRegular.attachments",
          "on": [
            {
              "ref": [
                "attachments",
                "up_"
              ]
            },
            "=",
            {
              "ref": [
                "$self"
              ]
            }
          ]
        },
        "submittable": {
          "@Core.Computed": true,
          "virtual": true,
          "type": "cds.Boolean",
          "default": {
            "val": true
          }
        },
        "backOffice": {
          "@UI.Hidden": true,
          "@Core.Computed": true,
          "virtual": true,
          "type": "cds.Boolean",
          "default": {
            "val": false
          }
        },
        "serialNumber": {
          "type": "cds.String"
        },
        "serialNumberEntity": {
          "type": "cds.Association",
          "cardinality": {
            "max": 1
          },
          "target": "kikuldetes.SerialNumbers",
          "keys": [
            {
              "ref": [
                "yearMonth"
              ]
            },
            {
              "ref": [
                "number"
              ]
            }
          ]
        },
        "editing": {
          "@Core.Computed": true,
          "virtual": true,
          "type": "cds.Boolean",
          "default": {
            "val": false
          }
        },
        "accepted": {
          "@Core.Computed": true,
          "virtual": true,
          "type": "cds.Boolean",
          "default": {
            "val": false
          }
        },
        "borrowedEUR": {
          "type": "cds.Decimal"
        },
        "borrowedHUF": {
          "type": "cds.Decimal"
        },
        "country": {
          "@title": "{i18n>Country}",
          "@description": "{i18n>CountryCode.Description}",
          "type": "Country",
          "target": "sap.common.Countries",
          "keys": [
            {
              "ref": [
                "code"
              ]
            }
          ]
        },
        "travel_to": {
          "@mandatory": true,
          "type": "cds.Date"
        },
        "travel_back": {
          "@mandatory": true,
          "type": "cds.Date"
        },
        "departures_arrivals": {
          "type": "cds.Composition",
          "cardinality": {
            "max": "*"
          },
          "target": "kikuldetes.DeparturesAndArrivals",
          "on": [
            {
              "ref": [
                "departures_arrivals",
                "posting"
              ]
            },
            "=",
            {
              "ref": [
                "$self"
              ]
            }
          ]
        },
        "daily_expenses": {
          "type": "cds.Composition",
          "cardinality": {
            "max": "*"
          },
          "target": "kikuldetes.DailyExpenses",
          "on": [
            {
              "ref": [
                "daily_expenses",
                "posting"
              ]
            },
            "=",
            {
              "ref": [
                "$self"
              ]
            }
          ]
        },
        "accomodations": {
          "type": "cds.Composition",
          "cardinality": {
            "max": "*"
          },
          "target": "kikuldetes.Accomodations",
          "on": [
            {
              "ref": [
                "accomodations",
                "posting"
              ]
            },
            "=",
            {
              "ref": [
                "$self"
              ]
            }
          ]
        },
        "material_expenses": {
          "type": "cds.Composition",
          "cardinality": {
            "max": "*"
          },
          "target": "kikuldetes.MaterialExpenses",
          "on": [
            {
              "ref": [
                "material_expenses",
                "posting"
              ]
            },
            "=",
            {
              "ref": [
                "$self"
              ]
            }
          ]
        },
        "trip_expenses": {
          "type": "cds.Composition",
          "cardinality": {
            "max": "*"
          },
          "target": "kikuldetes.TripExpenses",
          "on": [
            {
              "ref": [
                "trip_expenses",
                "posting"
              ]
            },
            "=",
            {
              "ref": [
                "$self"
              ]
            }
          ]
        },
        "messages": {
          "type": "cds.Composition",
          "cardinality": {
            "max": "*"
          },
          "target": "kikuldetes.RegularStatusMessages",
          "on": [
            {
              "ref": [
                "messages",
                "posting"
              ]
            },
            "=",
            {
              "ref": [
                "$self"
              ]
            }
          ]
        }
      }
    },
    "kikuldetes.DeparturesAndArrivals": {
      "kind": "entity",
      "elements": {
        "ID": {
          "key": true,
          "type": "cds.UUID"
        },
        "from_where": {
          "@mandatory": true,
          "type": "cds.String"
        },
        "departure": {
          "@mandatory": true,
          "type": "cds.DateTime"
        },
        "to_where": {
          "@mandatory": true,
          "type": "cds.String"
        },
        "arrival": {
          "@mandatory": true,
          "type": "cds.DateTime"
        },
        "posting": {
          "type": "cds.Association",
          "target": "kikuldetes.PostingsRegular",
          "keys": [
            {
              "ref": [
                "ID"
              ]
            }
          ]
        },
        "meanOfTransport": {
          "type": "cds.Association",
          "cardinality": {
            "max": 1
          },
          "target": "kikuldetes.MeansOfTransport",
          "keys": [
            {
              "ref": [
                "ID"
              ]
            }
          ]
        }
      }
    },
    "kikuldetes.Expense": {
      "kind": "aspect",
      "elements": {
        "days": {
          "@mandatory": true,
          "type": "cds.Integer"
        },
        "currency": {
          "@mandatory": true,
          "@title": "{i18n>Currency}",
          "@description": "{i18n>CurrencyCode.Description}",
          "type": "Currency",
          "target": "sap.common.Currencies",
          "keys": [
            {
              "ref": [
                "code"
              ]
            }
          ]
        },
        "daily_price": {
          "@mandatory": true,
          "type": "cds.Decimal",
          "precision": 10,
          "scale": 2
        },
        "ID": {
          "key": true,
          "type": "cds.UUID"
        },
        "paymentMethod": {
          "type": "cds.Association",
          "cardinality": {
            "max": 1
          },
          "target": "kikuldetes.PaymentMethods",
          "keys": [
            {
              "ref": [
                "ID"
              ]
            }
          ]
        },
        "date": {
          "@mandatory": true,
          "type": "cds.Date"
        },
        "posting": {
          "type": "cds.Association",
          "target": "kikuldetes.PostingsRegular",
          "keys": [
            {
              "ref": [
                "ID"
              ]
            }
          ]
        }
      }
    },
    "kikuldetes.DailyExpenses": {
      "kind": "entity",
      "includes": [
        "kikuldetes.Expense"
      ],
      "elements": {
        "days": {
          "@mandatory": true,
          "type": "cds.Integer"
        },
        "currency": {
          "@mandatory": true,
          "@title": "{i18n>Currency}",
